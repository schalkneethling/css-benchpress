{
  "name": "@schalkneethling/css-benchpress",
  "version": "0.0.1",
  "description": "A Playwright-powered harness for finding reproducible CSS performance regressions in framework-free fixtures.",
  "homepage": "https://github.com/schalkneethling/css-benchpress#readme",
  "bugs": {
    "url": "https://github.com/schalkneethling/css-benchpress/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schalkneethling/css-benchpress.git"
  },
  "bin": {
    "css-benchpress": "./dist/main.mjs"
  },
  "files": [
    "cases",
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "node --experimental-strip-types src/cli/main.ts",
    "test": "vp test",
    "lint": "vp check",
    "check": "vp check",
    "staged:check": "vp check --fix",
    "package:check": "publint",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "packageManager": "bun@1.3.14"
}
